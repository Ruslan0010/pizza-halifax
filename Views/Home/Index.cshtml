@model List<Category>
@{
    ViewData["Title"] = "Menu";
}

<section class="container mt-4">
    <div class="hero text-center d-flex flex-column justify-content-center align-items-center">
        <h1 class="brand mb-3">Pizza Halifax</h1>
        <p class="lead mb-4">Hand-stretched dough, wood-fired and delivered hot across Halifax.</p>
        <a href="#menu" class="btn btn-pz btn-lg px-4">Order Now</a>
    </div>
</section>

<section id="menu" class="container my-5">
    @foreach (var category in Model)
    {
        <h2 class="section-title">@category.Name</h2>
        <div class="row g-4 mb-5">
            @foreach (var product in category.Products)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card product-card">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />
                        </a>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1">@product.Name</h5>
                            <p class="card-text small text-muted flex-grow-1">@product.Description</p>
                            <div class="d-flex align-items-center justify-content-between mt-2">
                                <span class="price-tag">
                                    @(product.IsCustomizable ? "from " : "")$@product.BasePrice.ToString("0.00")
                                </span>
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-pz">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
