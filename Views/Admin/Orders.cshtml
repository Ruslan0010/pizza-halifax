@model List<Order>
@{
    ViewData["Title"] = "Orders";
    var statuses = Enum.GetValues<OrderStatus>();
}

<section class="container my-5">
    <h1 class="mb-4">Orders</h1>

    @if (Model.Count == 0)
    {
        <p class="text-muted">No orders yet.</p>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Placed</th>
                            <th style="min-width:220px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@o.OrderNumber</td>
                                <td>
                                    @o.CustomerName<br />
                                    <span class="small text-muted">@o.CustomerPhone</span>
                                </td>
                                <td class="small">
                                    @foreach (var item in o.Items)
                                    {
                                        <div>@item.Quantity × @item.ProductName</div>
                                    }
                                </td>
                                <td>$@o.Total.ToString("0.00")</td>
                                <td class="small text-muted">@o.CreatedAt.ToLocalTime().ToString("dd MMM, HH:mm")</td>
                                <td>
                                    <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2">
                                        <input type="hidden" name="id" value="@o.Id" />
                                        <select name="status" class="form-select form-select-sm">
                                            @foreach (var s in statuses)
                                            {
                                                if (s == o.Status)
                                                {
                                                    <option value="@s" selected>@s</option>
                                                }
                                                else
                                                {
                                                    <option value="@s">@s</option>
                                                }
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-pz">Update</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
