@model ProductFormViewModel
@{
    var isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Edit Product" : "Add Product";
}

<section class="container my-5">
    <a asp-action="Products" class="btn btn-link text-decoration-none ps-0 mb-3">&larr; Back to menu</a>
    <h1 class="mb-4">@(isEdit ? "Edit Product" : "Add Product")</h1>

    <div class="row">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <form asp-action="@(isEdit ? "EditProduct" : "CreateProduct")" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 mb-3">
                                <label asp-for="BasePrice" class="form-label"></label>
                                <input asp-for="BasePrice" class="form-control" />
                                <span asp-validation-for="BasePrice" class="text-danger small"></span>
                            </div>
                            <div class="col-sm-6 mb-3">
                                <label asp-for="CategoryId" class="form-label"></label>
                                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label"></label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="/images/menu/example.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            <div class="form-text">Path to an image under wwwroot, e.g. <code>/images/menu/margherita.jpg</code>.</div>
                        </div>

                        <div class="form-check mb-2">
                            <input asp-for="IsAvailable" class="form-check-input" />
                            <label asp-for="IsAvailable" class="form-check-label"></label>
                        </div>
                        <div class="form-check mb-4">
                            <input asp-for="IsCustomizable" class="form-check-input" />
                            <label asp-for="IsCustomizable" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-pz">@(isEdit ? "Save changes" : "Create product")</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
