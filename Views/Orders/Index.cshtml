@model List<Order>
@{
    ViewData["Title"] = "My Orders";
}

<section class="container my-5">
    <h1 class="mb-4">My Orders</h1>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <p class="fs-5 text-muted mb-4">You haven't placed any orders yet.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-pz btn-lg">Browse the menu</a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between flex-wrap mb-2">
                        <div>
                            <span class="fw-bold">@order.OrderNumber</span>
                            <span class="text-muted small ms-2">@order.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <span class="badge bg-secondary align-self-start">@order.Status</span>
                    </div>
                    @foreach (var item in order.Items)
                    {
                        <div class="small text-muted">
                            @item.Quantity × @item.ProductName@(item.SizeName is not null ? $" ({item.SizeName})" : "")
                        </div>
                    }
                    <div class="text-end fw-bold price-tag mt-2">$@order.Total.ToString("0.00")</div>
                </div>
            </div>
        }
    }
</section>
